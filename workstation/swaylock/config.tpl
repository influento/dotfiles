# swaylock — Screen locker for Sway

# Appearance
font=sans-serif
font-size=24
indicator-radius=100
indicator-thickness=10

# Behavior
ignore-empty-password
show-failed-attempts
daemonize

# Colors
# Background
color=@@BASE_RAW@@

# Inside (indicator center)
inside-color=@@BASE_RAW@@
inside-clear-color=@@BASE_RAW@@
inside-caps-lock-color=@@BASE_RAW@@
inside-ver-color=@@BASE_RAW@@
inside-wrong-color=@@BASE_RAW@@

# Ring
ring-color=@@LAVENDER_RAW@@
ring-clear-color=@@YELLOW_RAW@@
ring-caps-lock-color=@@PEACH_RAW@@
ring-ver-color=@@BLUE_RAW@@
ring-wrong-color=@@RED_RAW@@

# Line (between ring and inside)
line-uses-inside

# Key highlight
key-hl-color=@@GREEN_RAW@@
bs-hl-color=@@RED_RAW@@
caps-lock-key-hl-color=@@PEACH_RAW@@
caps-lock-bs-hl-color=@@RED_RAW@@

# Separator
separator-color=00000000

# Text
text-color=@@TEXT_RAW@@
text-clear-color=@@YELLOW_RAW@@
text-caps-lock-color=@@PEACH_RAW@@
text-ver-color=@@BLUE_RAW@@
text-wrong-color=@@RED_RAW@@
