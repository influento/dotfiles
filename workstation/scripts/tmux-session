#!/usr/bin/env bash
set -euo pipefail

# tmux-session — predefined tmux session launcher
# Usage: tmux-session <name>
# Attaches to the session if it exists, creates it if it doesn't.

INFRA_DIR="$HOME/dev/infra"

session_infra() {
  local dirs=(dotfiles gtk-widgets arch-install debian-server tmux-plugins)

  tmux new-session -d -s infra -n "${dirs[0]}" -c "$INFRA_DIR/${dirs[0]}"

  for dir in "${dirs[@]:1}"; do
    tmux new-window -t infra -n "$dir" -c "$INFRA_DIR/$dir"
  done

  for i in "${!dirs[@]}"; do
    local win=$((i + 1))
    tmux split-window -h -t "infra:${win}" -c "$INFRA_DIR/${dirs[$i]}"
    tmux send-keys -t "infra:${win}.2" "nvim +'Neotree'" Enter
    tmux select-pane -t "infra:${win}.1"
  done

  tmux select-window -t infra:1
}

attach_or_switch() {
  if [[ -n "${TMUX:-}" ]]; then
    tmux select-window -t "$1:1"
    tmux switch-client -t "$1"
  else
    tmux attach -t "$1"
  fi
}

start_session() {
  local name="$1"

  # Attach if session already exists
  if tmux has-session -t "$name" 2>/dev/null; then
    attach_or_switch "$name"
    return
  fi

  # Create session
  case "$name" in
    infra) session_infra ;;
    *)
      echo "Unknown session: $name" >&2
      echo "Available sessions: infra" >&2
      exit 1
      ;;
  esac

  attach_or_switch "$name"
}

if [[ $# -lt 1 ]]; then
  echo "Usage: tmux-session <name>" >&2
  echo "Available sessions: infra" >&2
  exit 1
fi

start_session "$1"
