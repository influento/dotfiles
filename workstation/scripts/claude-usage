#!/usr/bin/env python3
"""Fetch Claude subscription usage and output waybar-compatible JSON."""

import json
import sys
import urllib.request
from datetime import date, datetime, timezone
from pathlib import Path

CACHE_PATH = Path.home() / ".claude" / "subscription_cache.json"


def load_token():
    """Read OAuth access token from Claude Code credentials."""
    creds_path = Path.home() / ".claude" / ".credentials.json"
    with open(creds_path) as f:
        creds = json.load(f)
    return creds["claudeAiOauth"]["accessToken"]


def fetch_usage(token):
    """Call the Anthropic OAuth usage endpoint."""
    req = urllib.request.Request(
        "https://api.anthropic.com/api/oauth/usage",
        headers={
            "Authorization": f"Bearer {token}",
            "anthropic-beta": "oauth-2025-04-20",
        },
    )
    with urllib.request.urlopen(req, timeout=10) as resp:
        return json.loads(resp.read())


def load_cached_charge_date():
    """Read next_charge_date from cache if it exists and is in the future."""
    try:
        with open(CACHE_PATH) as f:
            cache = json.load(f)
        charge_date = cache.get("next_charge_date")
        if charge_date and datetime.strptime(charge_date, "%Y-%m-%d").date() >= date.today():
            return charge_date
    except (FileNotFoundError, json.JSONDecodeError, KeyError, ValueError):
        pass
    return None


def format_reset_relative(iso_str):
    """Format reset time as a relative duration string."""
    reset = datetime.fromisoformat(iso_str.replace("Z", "+00:00"))
    now = datetime.now(timezone.utc)
    delta = reset - now
    total_minutes = int(delta.total_seconds() / 60)
    if total_minutes < 0:
        return "now"
    total_hours, minutes = divmod(total_minutes, 60)
    if total_hours >= 24:
        days, hours = divmod(total_hours, 24)
        return f"{days}d {hours}h"
    if total_hours > 0:
        return f"{total_hours}h {minutes}m"
    return f"{minutes}m"


def format_reset_absolute(iso_str):
    """Format reset time as a local day and time (e.g., 'Fri 10:59 AM')."""
    reset = datetime.fromisoformat(iso_str.replace("Z", "+00:00"))
    local = reset.astimezone()
    return local.strftime("%a %-I:%M %p")


def format_date_relative(date_str):
    """Format a date string (YYYY-MM-DD) as relative duration."""
    target = datetime.strptime(date_str, "%Y-%m-%d").replace(tzinfo=timezone.utc)
    now = datetime.now(timezone.utc)
    delta = target - now
    total_hours = int(delta.total_seconds() / 3600)
    if total_hours < 0:
        return "now"
    if total_hours >= 24:
        days, hours = divmod(total_hours, 24)
        return f"{days}d {hours}h"
    minutes = int((delta.total_seconds() % 3600) / 60)
    return f"{total_hours}h {minutes}m"


def format_date_absolute(date_str):
    """Format a date string (YYYY-MM-DD) as readable date (e.g., 'Apr 3')."""
    target = datetime.strptime(date_str, "%Y-%m-%d")
    return target.strftime("%b %-d")


def classify(five_hour, seven_day):
    """Return CSS class based on the higher utilization."""
    peak = max(five_hour, seven_day)
    if peak > 95:
        return "high"
    if peak >= 80:
        return "medium"
    return "low"


def main():
    try:
        token = load_token()
        data = fetch_usage(token)

        if "--json" in sys.argv:
            charge_date = load_cached_charge_date()
            if charge_date:
                data["next_charge_date"] = charge_date
            print(json.dumps(data))
            return

        five = data["five_hour"]
        seven = data["seven_day"]
        sonnet = data.get("seven_day_sonnet")
        five_pct = round(five["utilization"])
        seven_pct = round(seven["utilization"])
        css_class = classify(five["utilization"], seven["utilization"])

        tooltip_lines = [
            f"5-hour:       {five_pct}%  resets {format_reset_absolute(five['resets_at'])} ({format_reset_relative(five['resets_at'])})",
            f"7-day:        {seven_pct}%  resets {format_reset_absolute(seven['resets_at'])} ({format_reset_relative(seven['resets_at'])})",
        ]
        if sonnet and sonnet.get("utilization") is not None:
            sonnet_pct = round(sonnet["utilization"])
            tooltip_lines.append(
                f"7-day sonnet: {sonnet_pct}%  resets {format_reset_absolute(sonnet['resets_at'])} ({format_reset_relative(sonnet['resets_at'])})"
            )

        charge_date = load_cached_charge_date()
        if charge_date:
            tooltip_lines.append(
                f"next charge:  {format_date_absolute(charge_date)} ({format_date_relative(charge_date)})"
            )

        output = {
            "text": f"5h {five_pct}% · 7d {seven_pct}%",
            "tooltip": "\n".join(tooltip_lines),
            "class": css_class,
        }
        print(json.dumps(output))

    except Exception:
        if "--json" in sys.argv:
            print(json.dumps({"error": "failed to fetch usage"}))
        else:
            print(json.dumps({"text": "—", "tooltip": "Failed to fetch usage", "class": "error"}))


if __name__ == "__main__":
    main()
