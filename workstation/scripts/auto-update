#!/usr/bin/env bash
set -euo pipefail

# auto-update — Silent background system update on sway startup.
# Runs yay -Syu (official repos + AUR) with a 12-hour cooldown. Sends mako
# notifications on success (low urgency, auto-dismiss) or failure (critical, persistent).

STATE_DIR="$HOME/.local/state/dotfiles"
LOG_FILE="${STATE_DIR}/auto-update.log"
LAST_FILE="${STATE_DIR}/auto-update-last"
LOCK_FILE="/tmp/.auto-update-${UID}.lock"
COOLDOWN=$((12 * 60 * 60))

mkdir -p "$STATE_DIR"

exec 9>"$LOCK_FILE"
if ! flock -n 9; then
  echo "Another auto-update is already running." >> "$LOG_FILE"
  exit 0
fi

# Cooldown — skip if last successful update was <12h ago
if [[ -f "$LAST_FILE" ]]; then
  last="$(cat "$LAST_FILE")"
  now="$(date +%s)"
  if (( now - last < COOLDOWN )); then
    echo "[$(date)] Skipping — last update was $(( (now - last) / 3600 ))h ago." >> "$LOG_FILE"
    exit 0
  fi
fi

# Wait for network (up to 60s)
for _ in $(seq 1 12); do
  if curl -sf --max-time 5 https://archlinux.org > /dev/null 2>&1; then
    break
  fi
  sleep 5
done

if ! curl -sf --max-time 5 https://archlinux.org > /dev/null 2>&1; then
  echo "[$(date)] No network after 60s — aborting." >> "$LOG_FILE"
  exit 0
fi

# Let system services (gpg-agent, keyboxd, etc.) settle after boot
sleep 60

# Refresh Arch mirrorlist if older than 7 days. Mirrors rot (dead hosts, new
# fast ones) on a days-to-weeks cadence — periodic refresh keeps the pool healthy.
# Country list mirrors arch-install defaults: auto-detected country (UA) +
# EU fallbacks (DE, NL, SE, FI, AT) for accessibility and redundancy.
# Keep in sync with arch-install/config.sh (MIRROR_FALLBACK_COUNTRIES).
MIRRORLIST=/etc/pacman.d/mirrorlist
if [[ ! -f "$MIRRORLIST" ]] || [[ -n "$(find "$MIRRORLIST" -mtime +7 -print)" ]]; then
  echo "[$(date)] Refreshing mirrorlist with reflector..." >> "$LOG_FILE"
  if reflector_out="$(sudo reflector \
    --country "UA,DE,NL,SE,FI,AT" \
    --latest 20 \
    --sort rate \
    --protocol https \
    --save "$MIRRORLIST" 2>&1)"; then
    echo "$reflector_out" >> "$LOG_FILE"
  else
    echo "$reflector_out" >> "$LOG_FILE"
    echo "[$(date)] reflector failed, keeping existing mirrorlist." >> "$LOG_FILE"
  fi
fi

# Restart gpg-agent/keyboxd and clean stale lock files.
# keyboxd can leave pubring.db.lock behind after a crash or unclean shutdown,
# which blocks all subsequent GPG operations indefinitely.
gpgconf --kill all
KEYBOXD_LOCK="$HOME/.gnupg/public-keys.d/pubring.db.lock"
if [[ -f "$KEYBOXD_LOCK" ]]; then
  lock_pid="$(lsof -t "$KEYBOXD_LOCK" 2>/dev/null || true)"
  if [[ -z "$lock_pid" ]]; then
    echo "[$(date)] Removing stale keyboxd lock (no process holding it)." >> "$LOG_FILE"
    rm -f "$KEYBOXD_LOCK"
  fi
fi
gpgconf --launch gpg-agent

# Check for available updates
pending="$(yay -Qu 2>/dev/null | wc -l || true)"
if (( pending == 0 )); then
  echo "[$(date)] No updates available." >> "$LOG_FILE"
else
  notify-send -u low "Updating System" "${pending} package(s) available..."

  # Run update with retry (3 attempts, 60s between retries)
  MAX_ATTEMPTS=3
  RETRY_DELAY=60

  for attempt in $(seq 1 "$MAX_ATTEMPTS"); do
    echo "[$(date)] Starting yay -Syu (attempt ${attempt}/${MAX_ATTEMPTS}, ${pending} pending)..." >> "$LOG_FILE"

    if output="$(yay -Syu --noconfirm 2>&1)"; then
      echo "$output" >> "$LOG_FILE"
      upgraded="$(echo "$output" | grep -c "^upgrading " || true)"
      notify-send -u low "System Updated" "${upgraded} package(s) upgraded."
      echo "[$(date)] Update complete — ${upgraded} package(s) upgraded." >> "$LOG_FILE"
      break
    fi

    echo "$output" >> "$LOG_FILE"

    # Extract error details: mirror 404s, file conflicts, or generic failure
    error_detail=""
    retrieval_fails="$(echo "$output" | grep -oP "failed retrieving file '\K[^']+(?=')" | sed 's/-[0-9].*//;s/\.pkg.*//' | sort -u | paste -sd', ' || true)"
    conflict_fails="$(echo "$output" | grep -oP "^[^:]+(?=: /)" | grep -v "^error$" | sort -u | paste -sd', ' || true)"
    if [[ -n "$retrieval_fails" ]]; then
      error_detail="Failed to retrieve: ${retrieval_fails}"
    elif [[ -n "$conflict_fails" ]]; then
      error_detail="File conflict in: ${conflict_fails}"
    else
      error_detail="yay -Syu failed"
    fi

    if (( attempt < MAX_ATTEMPTS )); then
      echo "[$(date)] Update FAILED (attempt ${attempt}/${MAX_ATTEMPTS}). Retrying in ${RETRY_DELAY}s..." >> "$LOG_FILE"
      notify-send -u critical "Update Failed (${attempt}/${MAX_ATTEMPTS})" \
        "${error_detail}. Retrying in ${RETRY_DELAY}s..."
      sleep "$RETRY_DELAY"
      # Re-check pending count in case mirrors synced
      pending="$(yay -Qu 2>/dev/null | wc -l || true)"
    else
      echo "[$(date)] Update FAILED (attempt ${attempt}/${MAX_ATTEMPTS}). Giving up." >> "$LOG_FILE"
      notify-send -u critical "Update Failed (${attempt}/${MAX_ATTEMPTS})" \
        "${error_detail}. Check ${LOG_FILE}"
    fi
  done
fi

# Update global npm packages from common + workstation packages.conf
DOTFILES_DIR="$(cd "$(dirname "$(readlink -f "$0")")/../.." && pwd)"
NPM_PACKAGE_FILES=(
  "${DOTFILES_DIR}/common/npm/packages.conf"
  "${DOTFILES_DIR}/workstation/npm/packages.conf"
)

npm_pkgs=()
for pkg_file in "${NPM_PACKAGE_FILES[@]}"; do
  [[ -f "$pkg_file" ]] || continue
  while IFS= read -r line || [[ -n "$line" ]]; do
    [[ "$line" =~ ^[[:space:]]*# ]] && continue
    [[ -z "${line// /}" ]] && continue
    npm_pkgs+=("$line")
  done < "$pkg_file"
done

if [[ ${#npm_pkgs[@]} -gt 0 ]]; then
  echo "[$(date)] Updating npm packages: ${npm_pkgs[*]}..." >> "$LOG_FILE"
  if npm_output="$(npm update -g "${npm_pkgs[@]}" 2>&1)"; then
    echo "$npm_output" >> "$LOG_FILE"
    echo "[$(date)] npm update complete." >> "$LOG_FILE"
    npm_changed="$(echo "$npm_output" | grep -oP 'changed \K\d+' || true)"
    if [[ -n "$npm_changed" ]] && (( npm_changed > 0 )); then
      notify-send -u low "npm Updated" "${npm_changed} package(s) updated."
    fi
  else
    echo "$npm_output" >> "$LOG_FILE"
    echo "[$(date)] npm update FAILED." >> "$LOG_FILE"
    notify-send -u critical "npm Update Failed" "See ${LOG_FILE}"
  fi
fi

date +%s > "$LAST_FILE"
