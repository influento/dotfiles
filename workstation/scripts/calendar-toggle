#!/usr/bin/env bash
set -euo pipefail

# Toggle calendar popup. Uses flock to prevent duplicates.

LOCKFILE="/tmp/.calendar-toggle.lock"

exec 9>"$LOCKFILE"
if ! flock -n 9; then
  if pgrep -f "calendar-popup" >/dev/null 2>&1; then
    pkill -f "calendar-popup"
  fi
  exit 0
fi

if pgrep -f "calendar-popup" >/dev/null 2>&1; then
  pkill -f "calendar-popup"
  flock -u 9
else
  flock -u 9
  "$HOME/.local/bin/calendar-popup"
  exec 9>"$LOCKFILE"
  flock -n 9 && sleep 0.5
fi
