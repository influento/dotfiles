#!/usr/bin/env bash
set -euo pipefail

# Toggle scaling popup. Uses flock to prevent duplicates.

LOCKFILE="/tmp/.scaling-toggle.lock"

exec 9>"$LOCKFILE"
if ! flock -n 9; then
  if pgrep -f "scaling-popup" >/dev/null 2>&1; then
    pkill -f "scaling-popup"
  fi
  exit 0
fi

if pgrep -f "scaling-popup" >/dev/null 2>&1; then
  pkill -f "scaling-popup"
  flock -u 9
else
  flock -u 9
  "$HOME/.local/bin/scaling-popup"
  exec 9>"$LOCKFILE"
  flock -n 9 && sleep 0.5
fi
